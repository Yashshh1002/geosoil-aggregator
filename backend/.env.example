# GeoSoil Aggregator Backend Configuration
# Copy this to .env and adjust as needed

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ISRIC SoilGrids API (no auth needed)
ISRIC_BASE_URL=https://rest.isric.org/soilgrids/v2.0

# Open Elevation API
ELEVATION_API_URL=https://api.open-elevation.com/api/v1/lookup

# Rate limiting
ISRIC_MAX_REQUESTS_PER_MINUTE=4

# Cache TTL (seconds)
SOIL_CACHE_TTL=3600
ELEVATION_CACHE_TTL=86400
